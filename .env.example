# Hudu MCP Server Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════
# REQUIRED: Hudu API Configuration
# ═══════════════════════════════════════════════════
HUDU_BASE_URL=https://your-company.huducloud.com
HUDU_API_KEY=your-hudu-api-key-here

# ═══════════════════════════════════════════════════
# MCP Transport Configuration (HTTP ONLY)
# ═══════════════════════════════════════════════════
# This server ONLY supports HTTP transport as per CLAUDE.md requirements
# NO STDIO or SSE transport - HTTP exclusively for all clients

# HTTP Transport Port (required)
MCP_SERVER_PORT=3100

# Bearer token for MCP HTTP authentication (optional but recommended)
# Generate a secure token for production use
MCP_BEARER_TOKEN=your-secure-bearer-token-here

# ═══════════════════════════════════════════════════
# Optional: Advanced Configuration
# ═══════════════════════════════════════════════════
# Hudu API request timeout in milliseconds (default: 30000)
HUDU_TIMEOUT=30000

# Company ID filtering for multi-tenant access control
# Use "ALL" for unrestricted access (default, retrocompatible)
# Use comma-separated company IDs for filtered access
# Examples:
#   HUDU_ALLOWED_COMPANY_IDS=ALL              # Access all companies (current behavior)
#   HUDU_ALLOWED_COMPANY_IDS=123              # Access only company ID 123
#   HUDU_ALLOWED_COMPANY_IDS=123,456,789      # Access companies 123, 456, and 789
HUDU_ALLOWED_COMPANY_IDS=ALL

# Comma-separated list of allowed CORS origins for HTTP transport
# Default: localhost, 127.0.0.1, and RFC1918 private networks (192.168.x.x, 10.x.x.x, 172.16-31.x.x)
# Examples:
#   MCP_ALLOWED_ORIGINS=http://localhost,http://192.168.1.100
#   MCP_ALLOWED_ORIGINS=http://workstation1.local,http://workstation2.local
# Leave blank to use secure defaults (recommended for local network deployment)
# MCP_ALLOWED_ORIGINS=

# Environment: "development" or "production"
# Production mode enables additional security features
NODE_ENV=development

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ═══════════════════════════════════════════════════
# OAuth 2.1 / Azure AD (required when MCP_OAUTH_ENABLED=true)
# Enables MCP OAuth 2.1 for Claude.ai custom connectors
# ═══════════════════════════════════════════════════
MCP_OAUTH_ENABLED=false

# Public HTTPS URL of this MCP server (required for OAuth metadata)
MCP_SERVER_URL=https://your-mcp-server.yourdomain.com

# Azure AD tenant and app registration
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-client-id

# Audience claim to validate in access tokens.
# Use "api://<AZURE_CLIENT_ID>" if you exposed an API scope in the Azure app.
# Use the client_id directly if using id_tokens or default audience.
AZURE_AUDIENCE=api://your-azure-app-client-id